;mode800
;gameid nijyuuei_remake

*define

language japanese
nsa
clickskippage
;transmode alpha

defvoicevol 100
defsevol 90
defbgmvol 60

game

*start
setwindow4 65,510,630,4,10,10,10,5,20,0,0,"bg\Mw_01.png",20,500,1

*title
bg "bg/logo1.png",10,800
#FFFFFF「二重影」ONScripter 重制版\
select "▶ 开始正篇","*ch001_start","▶ 番外篇","*ch101_start","▶ 章节选择","*chapter_select","▶ 退出","*do_quit"

*do_quit
end

*chapter_select
inputnum %900,"输入正篇章节号(1-46)，0返回标题",300,260,200,60
if %900 = 0 goto *title
if %900 < 1 goto *chapter_select
if %900 > 46 goto *chapter_select
tablegoto %900,*title,*ch001_start,*ch002_start,*ch003_start,*ch004_start,*ch005_start,*ch006_start,*ch007_start,*ch008_start,*ch009_start,*ch010_start,*ch011_start,*ch012_start,*ch013_start,*ch014_start,*ch015_start,*ch016_start,*ch017_start,*ch018_start,*ch019_start,*ch020_start,*ch021_start,*ch022_start,*ch023_start,*ch024_start,*ch025_start,*ch026_start,*ch027_start,*ch028_start,*ch029_start,*ch030_start,*ch031_start,*ch032_start,*ch033_start,*ch034_start,*ch035_start,*ch036_start,*ch037_start,*ch038_start,*ch039_start,*ch040_start,*ch041_start,*ch042_start,*ch043_start,*ch044_start,*ch045_start,*ch046_start

*bonus_select
inputnum %901,"输入番外章节号(101-118)，0返回标题",300,260,200,60
if %901 = 0 goto *title
if %901 < 101 goto *bonus_select
if %901 > 118 goto *bonus_select
sub %901,100
tablegoto %901,*title,*ch101_start,*ch102_start,*ch103_start,*ch104_start,*ch105_start,*ch106_start,*ch107_start,*ch108_start,*ch109_start,*ch110_start,*ch111_start,*ch112_start,*ch113_start,*ch114_start,*ch115_start,*ch116_start,*ch117_start,*ch118_start

*ch001_start
dwave 1,"se/001.wav"
dwave 1,"se/002.wav"
dwave 1,"se/003.wav"
